{
  "name": "siyer-atlas",
  "version": "3.9.0",
  "private": true,
  "type": "module",
  "description": "Interactive atlas of the Prophetic Era (570–661 CE) — maps, timelines, digital museum, relationship networks",
  "author": "Dr. Ali Çetinkaya",
  "homepage": "https://siyeratlas.org",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
